# data folder — exclude everything except telco.csv
data/*
data/raw/*
!data/raw/telco.csv

# models folder — exclude everything except the pkl files needed for Lambda
models/*
!models/xgb_pipeline.pkl
!models/xgboost_churn.pkl
!models/encoders.pkl
!models/feature_names_35.pkl
!models/feature_names_36.pkl
!models/threshold.pkl
!models/shap_explainer.pkl
!models/shap_values_test.csv

